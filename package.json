{
  "name": "tradeaero-indexing",
  "version": "1.0.0",
  "description": "Auto-submits newly published TradeAero listings to IndexNow and Google",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "dependencies": {
    "@sentry/node": "^10.57.0",
    "@supabase/supabase-js": "^2.105.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "tsx": "^4.22.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
