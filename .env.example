# ============================================================
# Required
# ============================================================

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (bypasses RLS — keep secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# IndexNow API key — generate a random UUID or hex string
# Must match the file content served at https://trade.aero/{INDEXNOW_API_KEY}.txt
# Add that file to tradeaero-refactor/public/{INDEXNOW_API_KEY}.txt
INDEXNOW_API_KEY=your-indexnow-api-key-here

# ============================================================
# Google Indexing API (optional but recommended)
# ============================================================
# When set, submits URLs directly to Google for near-instant indexing.
# When omitted, falls back to a slower sitemap ping.
#
# Setup:
#   1. Create a GCP project and enable the "Web Search Indexing API"
#   2. Create a Service Account and download its JSON key
#   3. In Google Search Console → Settings → Users and permissions,
#      add the service account email as an "Owner" of trade.aero
#   4. Paste the entire JSON key file as a single-line string below
#      (replace newlines with \n, or use a secrets manager)
#
# Daily quota: 200 URL notifications per Search Console property.
# Default mode submits 1 URL/listing (canonical English) → ~200 listings/day.
# Set GOOGLE_INDEXING_ALL_LOCALES=true to submit all 14 locale URLs/listing
# (~14 listings/day) — only useful if you have increased quota from Google.

GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Submit all 14 locale URLs per listing to Google (default: false = canonical only)
GOOGLE_INDEXING_ALL_LOCALES=false

# ============================================================
# Optional — behaviour tuning
# ============================================================

# Lookback window for discovering new listings in minutes (default: 60)
# Set to 10080 (1 week) for a full backfill dry-run
INDEXING_LOOKBACK_MINUTES=60

# Dry run: discover and enqueue events but do NOT call external APIs (default: false)
# Use true to validate URL generation and deduplication before going live
INDEXING_DRY_RUN=false

# Max URLs per IndexNow batch request (default: 100 listings x 14 locales = 1400 URLs)
# IndexNow supports up to 10,000 URLs per request
INDEXNOW_BATCH_SIZE=100

# Logging verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info
